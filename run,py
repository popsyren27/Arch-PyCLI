import asyncio
import sys
import signal
import logging
import threading
from core.kernel import KernelOrchestrator
from core.security import SecurityKernel
from core.network import DistributedNode
from core.interface import SystemInterface
from core.storage import EncryptedVFS

# Finalizing the Global OS Logger
logging.basicConfig(
    level=logging.INFO,
    format='[%(asctime)s] [SYSTEM_BOOT] [%(levelname)s] %(message)s',
    handlers=[logging.StreamHandler(sys.stdout)]
)
logger = logging.getLogger("BOOTLOADER")

class DistributedOS:
    """
    The Master Controller that ties the Control Plane and Execution Plane together.
    """
    def __init__(self):
        self.running = True
        
        # 1. Layer 0: Hardware & Security (The Root of Trust)
        self.security = SecurityKernel()
        
        # 2. Layer 1: Infrastructure (Storage & Network)
        self.storage = EncryptedVFS(security_kernel=self.security)
        self.network = DistributedNode(port=9999) # Default cluster port
        
        # 3. Layer 2: Orchestration (The Kernel)
        self.kernel = KernelOrchestrator(tools_dir="tools")
        
        # 4. Layer 3: The Secure Bridge (Userland API)
        self.api = SystemInterface(
            kernel=self.kernel, 
            security=self.security, 
            network=self.network
        )

    def handle_exit(self, signum, frame):
        """Ensures the VM shuts down without corrupting the Encrypted Vault."""
        logger.warning(f"Shutdown signal ({signum}) received. Cleaning up resources...")
        self.running = False
        # Perform emergency vault commit if needed
        sys.exit(0)

    async def boot(self):
        """
        The Sequential Boot Process. 
        Each layer must validate the previous one before proceeding.
        """
        logger.info("--- Starting Py-Arch Distributed CLI VM OS ---")
        
        # Set up OS-level signal intercepts
        signal.signal(signal.SIGINT, self.handle_exit)
        signal.signal(signal.SIGTERM, self.handle_exit)

        # Step A: Security Validation
        logger.info(f"Hardware Identity Verified: {self.security.hw_id[:16]}...")

        # Step B: Network Discovery (Non-blocking)
        # We start the network plane in the background
        network_task = asyncio.create_task(self.network.start())
        logger.info("Network Plane active. Searching for cluster peers...")

        # Step C: Kernel Discovery
        # Scan the 'tools/' folder for attack simulations
        self.kernel.bootstrap()

        # Step D: Execution Loop
        logger.info("OS fully initialized. Entering Execution Mode.")
        
        try:
            while self.running:
                for tool_name in self.kernel.registry:
                    logger.info(f"Invoking Tool: {tool_name}")
                    # Execute tool via the Secure Interface (Isolation)
                    self.kernel.execute_tool(tool_name, self.api, timeout=15)
                
                # Sleep cycle to prevent CPU thrashing in the CLI loop
                await asyncio.sleep(10) 
                
        except Exception as e:
            logger.critical(f"KERNEL PANIC: Unhandled exception in main loop: {e}")
        finally:
            network_task.cancel()

if __name__ == "__main__":
    # Initialize the Async Event Loop for the Distributed Plane
    os_instance = DistributedOS()
    try:
        asyncio.run(os_instance.boot())
    except KeyboardInterrupt:
        pass # Handled by handle_exit